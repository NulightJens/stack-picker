{
  "name": "stack-picker",
  "version": "0.1.0",
  "description": "Interactive tech-stack picker — build your stack, ship it.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 execute stack-picker-db --local --file=migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute stack-picker-db --remote --file=migrations/0001_initial.sql",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260316.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  }
}
